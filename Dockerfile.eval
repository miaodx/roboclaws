ARG PYTHON_IMAGE=python:3.12-slim-bookworm@sha256:76d4b7b6305788c6b4c6a19d6a22a3921bf802e9af4d5e1e5bd771208dba74bf
FROM ${PYTHON_IMAGE}

ARG JUST_VERSION=1.51.0
ARG TARGETARCH
ARG UV_VERSION=0.9.27

LABEL org.opencontainers.image.title="roboclaws-eval"
LABEL org.opencontainers.image.description="Offline-capable Roboclaws eval runtime for CloudML/JuiceFS formal evidence"

ENV DEBIAN_FRONTEND=noninteractive
ENV ROBOCLAWS_DEVTOOLS_PYTHON=/opt/roboclaws/.venv/bin/python
ENV UV_LINK_MODE=copy
ENV UV_PROJECT_ENVIRONMENT=/opt/roboclaws/.venv
ENV PATH=/opt/roboclaws/.venv/bin:/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        build-essential \
        ca-certificates \
        curl \
        git \
        jq \
        libegl1 \
        libgl1 \
        libglib2.0-0 \
        libgomp1 \
        libosmesa6 \
        libsm6 \
        libxext6 \
        libxrender1 \
        openssh-client \
        pkg-config \
    && rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    case "${TARGETARCH:-amd64}" in \
      amd64) just_target="x86_64-unknown-linux-musl" ;; \
      arm64) just_target="aarch64-unknown-linux-musl" ;; \
      *) echo "unsupported TARGETARCH for just: ${TARGETARCH:-unset}" >&2; exit 1 ;; \
    esac; \
    curl -fsSL \
      "https://github.com/casey/just/releases/download/${JUST_VERSION}/just-${JUST_VERSION}-${just_target}.tar.gz" \
      -o /tmp/just.tar.gz; \
    tar -xzf /tmp/just.tar.gz -C /usr/local/bin just; \
    rm /tmp/just.tar.gz; \
    just --version

RUN python -m pip install --no-cache-dir "uv==${UV_VERSION}" \
    && uv --version

ARG HATCHLING_VERSION=1.27.0
ARG EDITABLES_VERSION=0.6

WORKDIR /opt/roboclaws
COPY pyproject.toml uv.lock README.md LICENSE ./
RUN uv sync --extra dev --frozen --no-install-project \
    && uv pip install --python "$ROBOCLAWS_DEVTOOLS_PYTHON" \
        "hatchling==${HATCHLING_VERSION}" \
        "editables==${EDITABLES_VERSION}" \
    && "$ROBOCLAWS_DEVTOOLS_PYTHON" -c "import numpy, PIL, jinja2"

WORKDIR /workspace/roboclaws
CMD ["bash"]
