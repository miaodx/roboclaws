<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Autonomous nav replay — {{ run_id }}</title>
    <style>
      body {
        font-family: ui-sans-serif, system-ui, sans-serif;
        margin: 24px;
        color: #222;
      }
      .header {
        margin-bottom: 16px;
      }
      .header h1 {
        margin: 0 0 4px 0;
      }
      .run-id {
        color: #666;
        margin-bottom: 12px;
      }
      .stats {
        display: flex;
        flex-wrap: wrap;
        gap: 12px 24px;
        font-size: 14px;
        color: #555;
      }
      .timeline {
        display: flex;
        align-items: flex-start;
        overflow-x: auto;
        gap: 6px;
        padding: 12px 0;
        border-top: 1px solid #ddd;
        border-bottom: 1px solid #ddd;
      }
      .frame {
        min-width: {{ thumbnail_size * 2 + 12 }}px;
        max-width: {{ thumbnail_size * 2 + 12 }}px;
        position: relative;
        background: #fff;
        border-radius: 6px;
        padding: 4px;
      }
      .image-strip {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 4px;
      }
      .image-panel img {
        width: 100%;
        display: block;
      }
      .image-label {
        font-size: 11px;
        color: #666;
        margin: 2px 0 4px 0;
      }
      .frame.seen {
        border: 3px solid #2ca02c;
      }
      .frame.unseen {
        border: 2px dashed #888888;
      }
      .frame .badge {
        position: absolute;
        top: 2px;
        right: 2px;
        font-size: 16px;
        padding: 0 4px;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 3px;
      }
      .decision {
        display: inline-block;
        margin-top: 6px;
        padding: 2px 6px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
      }
      .decision.observe {
        background: #e8f5e9;
        color: #1b5e20;
      }
      .decision.fresh-observe {
        background: #e3f2fd;
        color: #0d47a1;
      }
      .decision.reasoned-batch {
        background: #fff8e1;
        color: #8d6e00;
      }
      .decision.blind-batch {
        background: #ffebee;
        color: #b71c1c;
      }
      .decision.move {
        background: #eeeeee;
        color: #555;
      }
      .frame .meta {
        font-size: 12px;
        color: #555;
        margin-top: 4px;
      }
      .frame .human-note {
        margin-top: 6px;
        background: #fff3cd;
        color: #6a4f00;
        padding: 4px 6px;
        font-size: 12px;
        border-radius: 4px;
      }
      .log {
        font-family: ui-monospace, Menlo, monospace;
        font-size: 12px;
        margin-top: 24px;
        background: #f6f6f6;
        padding: 12px;
        border-radius: 4px;
      }
      .log h2 {
        margin-top: 0;
        font-family: ui-sans-serif, system-ui, sans-serif;
      }
      .log-entry {
        margin-bottom: 6px;
      }
      .human {
        background: #fff3cd;
        padding: 0 4px;
      }
    </style>
  </head>
  <body>
    <div class="header">
      <h1>Autonomous nav replay</h1>
      <div class="run-id">run_id: {{ run_id }}</div>
      <div class="stats">
        <span>terminated_by: <b>{{ summary.terminated_by }}</b></span>
        <span>wallclock: <b>{{ "%.1f"|format(summary.wallclock_seconds) }}s</b></span>
        <span>observes: <b>{{ summary.observes_by_agent }}</b></span>
        <span>moves: <b>{{ summary.moves }}</b></span>
        <span>unseen frames: <b>{{ summary.frames_unseen_by_agent }}</b></span>
        <span>observe/move: <b>{{ "%.2f"|format(summary.observe_to_move_ratio) }}</b></span>
        <span>
          decision modes:
          <b>{{ summary.decision_modes.fresh_observe }}</b> fresh /
          <b>{{ summary.decision_modes.reasoned_batch }}</b> reasoned /
          <b>{{ summary.decision_modes.blind_batch }}</b> blind
        </span>
        <span>human msgs: <b>{{ summary.human_messages_delivered }}</b></span>
      </div>
    </div>

    <div class="timeline">
      {% for item in timeline %}
      {% if item.kind == "frame" %}
      <div class="frame {{ 'seen' if item.seen_by_agent else 'unseen' }}" title="{{ item.tooltip }}">
        <div class="image-strip">
          <div class="image-panel">
            <img src="data:image/jpeg;base64,{{ item.fpv }}" alt="fpv">
            <div class="image-label">FPV</div>
          </div>
          <div class="image-panel">
            <img src="data:image/jpeg;base64,{{ item.overhead }}" alt="overhead">
            <div class="image-label">Overhead</div>
          </div>
        </div>
        <span class="badge">{{ item.badge }}</span>
        <div class="decision {{ item.decision_class }}">{{ item.decision_label }}</div>
        <div class="meta">{{ "%.1f"|format(item.ts) }}s · {{ item.tool }}{% if item.move_direction %} · {{ item.move_direction }}{% endif %}</div>
        <div class="meta">{{ item.position }}</div>
        {% if item.human_message %}
        <div class="human-note">human_message: {{ item.human_message }}</div>
        {% endif %}
      </div>
      {% endif %}
      {% endfor %}
    </div>

    <div class="log">
      <h2>Tool-call log</h2>
      {% for entry in tool_log %}
      <div class="log-entry">
        [{{ "%7.2f"|format(entry.ts) }}s] {{ entry.tool }}: {{ entry.summary }}
        {% if entry.human_message %}
        <span class="human">human_message: {{ entry.human_message }}</span>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </body>
</html>
