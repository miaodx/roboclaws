# Pinned coding-agent CLI toolchain.
#
# Source this file from shell scripts; callers may override any value before
# sourcing. Keep package versions exact so local and CI runs move deliberately.

: "${ROBOCLAWS_CODE_AGENT_NODE_IMAGE:=node:22-bookworm-slim@sha256:689c11043dad91472750cd824c97dd5e2318e9dd6f954e492fe7af0135d33ceb}"
: "${ROBOCLAWS_CODEX_NPM_PACKAGE:=@openai/codex@0.130.0}"
: "${ROBOCLAWS_CLAUDE_CODE_NPM_PACKAGE:=@anthropic-ai/claude-code@2.1.143}"
: "${ROBOCLAWS_CODE_AGENT_IMAGE:=roboclaws-coding-agents:codex-0.130.0-claude-2.1.143}"

export ROBOCLAWS_CODE_AGENT_NODE_IMAGE
export ROBOCLAWS_CODEX_NPM_PACKAGE
export ROBOCLAWS_CLAUDE_CODE_NPM_PACKAGE
export ROBOCLAWS_CODE_AGENT_IMAGE
