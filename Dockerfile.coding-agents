ARG ROBOCLAWS_NODE_IMAGE=node:22-bookworm-slim@sha256:689c11043dad91472750cd824c97dd5e2318e9dd6f954e492fe7af0135d33ceb
FROM ${ROBOCLAWS_NODE_IMAGE}

ARG CODEX_NPM_PACKAGE=@openai/codex@0.130.0
ARG CLAUDE_CODE_NPM_PACKAGE=@anthropic-ai/claude-code@2.1.143

LABEL org.opencontainers.image.title="roboclaws-coding-agents"
LABEL org.opencontainers.image.description="Pinned Codex and Claude Code CLI runtime for Roboclaws live-agent demos"

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        git \
        jq \
        openssh-client \
        python3 \
        ripgrep \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g "${CODEX_NPM_PACKAGE}" "${CLAUDE_CODE_NPM_PACKAGE}" \
    && codex --version \
    && claude --version

WORKDIR /workspace
CMD ["bash"]
