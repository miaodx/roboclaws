KIMI_API_KEY=sk-xx
NV_API_KEY=nvapi-xx
MIMO_TP_KEY=tp-xx

# Optional per-demo coding-agent provider overrides. Defaults are `system`,
# which leaves Codex / Claude Code on their normal machine configuration.
#
# Codex profiles use OpenAI-compatible endpoints through per-invocation `-c`
# config; Claude profiles scope ANTHROPIC_API_KEY / ANTHROPIC_BASE_URL to that
# one launched process and default CLAUDE_CODE_SIMPLE=1 for that invocation.
# Secrets stay in this repo-local .env.
#
# ROBOCLAWS_CODEX_PROVIDER=system|kimi-openai|mimo-openai
# ROBOCLAWS_CLAUDE_PROVIDER=system|kimi-anthropic|mimo-anthropic
# ROBOCLAWS_CODE_AGENT_PROVIDER=system
#
# Existing model vars override the selected profile's default model.
# ROBOCLAWS_CODE_AGENT_MODEL=gpt-5.2
# ROBOCLAWS_CODEX_MODEL=gpt-5.2
# ROBOCLAWS_CLAUDE_MODEL=sonnet
#
# Optional pinned Docker runtime for Codex / Claude Code CLIs. Build/install
# wrappers with `just code::docker-install-wrappers .tmp/coding-agent-bin`,
# then prepend that directory to PATH for a run.
# ROBOCLAWS_CODE_AGENT_IMAGE=roboclaws-coding-agents:codex-0.130.0-claude-2.1.143
# ROBOCLAWS_CODE_AGENT_DOCKER_USE_HOST_CODEX_HOME=1  # opt in to host ~/.codex auth
#
# Example: Codex + MiMo.
# ROBOCLAWS_CODEX_PROVIDER=mimo-openai
# ROBOCLAWS_CODEX_MODEL=mimo-v2.5-pro
#
# Example: Claude Code + Kimi.
# ROBOCLAWS_CLAUDE_PROVIDER=kimi-anthropic
# ROBOCLAWS_CLAUDE_MODEL=kimi-k2.6
