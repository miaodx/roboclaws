# Default repo-local Codex route: codex-env, Responses API.
# Benchmark model: gpt-5.5
CODEX_BASE_URL=
CODEX_API_KEY=

# MiMo token-plan routes.
# OpenAI Chat benchmark models: mimo-v2.5, mimo-v2.5-pro
# Anthropic route model: mimo-v2.5
MIMO_OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
MIMO_TP_KEY=

# MiMo inside route for default-enabled on-demand UltraSpeed probes.
# OpenAI Chat benchmark models: mimo-v2.5, mimo-v2.5-pro, mimo-1000
MIMO_BASE_URL=
MIMO_API_KEY=

# Internal multi-model aggregator / mify route.
# Responses benchmark models: xiaomi/mimo-v2.5, xiaomi/mimo-v2.5-pro
# Anthropic benchmark model: xiaomi/mimo-v2.5
XM_LLM_BASE_URL=https://api.llm.mioffice.cn/v1
XM_LLM_ANTHROPIC_BASE_URL=https://api.llm.mioffice.cn/anthropic
XM_LLM_API_KEY=

# Kimi coding routes.
# OpenAI Chat benchmark model: kimi-k2.7-code. K2.7 Code uses provider-side
# Thinking On; do not add a thinking=disabled override.
# Anthropic benchmark model: k2.6
KIMI_OPENAI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_ANTHROPIC_BASE_URL=https://api.kimi.com/coding/
KIMI_API_KEY=

# NVIDIA NIM OpenAI-compatible route.
# Benchmark model: nvidia/llama-3.1-nemotron-nano-vl-8b-v1
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NV_API_KEY=

# Optional MiniMax Responses route. Codex and OpenAI Agents SDK use this only
# when ROBOCLAWS_CODEX_PROVIDER=minimax is set explicitly.
# Benchmark models: MiniMax-M3, MiniMax-M2.7-highspeed
MM_BASE_URL=https://api.minimaxi.com/v1
MM_API_KEY=

# Provider/model defaults, key names, wire APIs, and route health live in
# roboclaws/agents/provider_registry.py. camera-raw-fpv runs require a route
# with verified runtime image transport, not only an image-capable model id.
