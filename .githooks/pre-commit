#!/usr/bin/env bash
# Pre-commit hook: ruff (lint + format) + scoped tests.
#
# Install once per clone:
#
#     just dev::install-hooks    # or: git config core.hooksPath .githooks
#
# Bypass in emergencies:
#
#     git commit --no-verify     # skips this hook entirely
#     SKIP_TESTS=1 git commit    # skips tests but keeps the ruff gate
#
# Auto-skip:
#
#     Tests are auto-skipped when no .py / .toml / .lock files are staged
#     (doc-only commits don't pay the test cost). Python commits run scoped
#     tests when the hook can infer a relevant target. Set FORCE_TESTS=1
#     to run the full non-integration suite.
#
# Design notes:
#   - Tests marked `@pytest.mark.integration` (Docker-dependent OR real
#     model-provider API calls) are excluded via `-m "not integration"`.
#     Run them post-merge with `just dev::test-integration`, and CI still
#     runs the full suite.
#   - We run tests through the standalone wrapper to avoid host-wide ROS
#     contamination leaking into PYTHONPATH (and breaking `lark` import).
#   - No network calls. The Docker-gated integration tests auto-skip
#     without Docker anyway, but the `integration` marker keeps the
#     hook fast even when Docker IS installed (saves ~80s).

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# --- Ruff: lint + format check -------------------------------------------
if command -v ruff >/dev/null 2>&1; then
    RUFF=ruff
elif [[ -x .venv/bin/ruff ]]; then
    RUFF=.venv/bin/ruff
else
    echo "pre-commit: ruff not found on PATH or in .venv — install with 'pip install -e .[dev]'" >&2
    exit 1
fi

# Lint only the Python files actually staged for this commit. The repo
# has older accumulated lint debt in unrelated files; whole-tree `ruff
# check .` would block every commit regardless of scope. CI keeps the
# whole-tree gate (`ruff check .` on push/PR).
STAGED_PY="$(git diff --cached --name-only --diff-filter=ACMR -- '*.py' || true)"

if [[ -n "$STAGED_PY" ]]; then
    echo "pre-commit: ruff check (staged .py files)"
    # shellcheck disable=SC2086
    "$RUFF" check $STAGED_PY
    echo "pre-commit: ruff format --check (staged .py files)"
    # shellcheck disable=SC2086
    "$RUFF" format --check $STAGED_PY
else
    echo "pre-commit: no staged .py files — skipping ruff"
fi

# --- Pytest: fast subset --------------------------------------------------
if [[ "${SKIP_TESTS:-0}" == "1" ]]; then
    echo "pre-commit: SKIP_TESTS=1 set — skipping pytest"
    exit 0
fi

# Auto-skip pytest when no code-relevant files are staged. Doc-only
# commits (markdown, .gitignore, .yml without test impact) shouldn't pay
# the pytest cost. Override with FORCE_TESTS=1 if a change outside the
# globs below affects test results.
STAGED_CODE="$(git diff --cached --name-only --diff-filter=ACMR -- '*.py' '*.toml' '*.lock' || true)"

if [[ -z "$STAGED_CODE" && "${FORCE_TESTS:-0}" != "1" ]]; then
    echo "pre-commit: no staged .py/.toml/.lock files — skipping pytest (set FORCE_TESTS=1 to override)"
    exit 0
fi

# Require wrapper script so pytest always runs in the sanitized environment.
if [[ ! -x scripts/dev/run_pytest_standalone.sh ]]; then
    echo "pre-commit: scripts/dev/run_pytest_standalone.sh missing or not executable" >&2
    exit 1
fi

run_full_fast_tests() {
    echo "pre-commit: pytest -m 'not integration' (full fast subset)"
    ./scripts/dev/run_pytest_standalone.sh -m "not integration" -q --durations=5
}

add_test_target() {
    local target="$1"
    [[ -e "$target" ]] || return 0
    local existing
    for existing in "${TEST_TARGETS[@]}"; do
        [[ "$existing" == "$target" ]] && return 0
    done
    TEST_TARGETS+=("$target")
}

infer_tests_for_path() {
    local path="$1"
    case "$path" in
        tests/*.py|tests/*/*.py|tests/*/*/*.py)
            add_test_target "$path"
            ;;
        roboclaws/operator_console/*)
            add_test_target "tests/unit/operator_console"
            ;;
        roboclaws/core/providers/*)
            add_test_target "tests/unit/providers"
            ;;
        roboclaws/core/*|roboclaws/ai2thor/*)
            add_test_target "tests/unit/core"
            ;;
        roboclaws/games/*)
            add_test_target "tests/unit/games"
            ;;
        roboclaws/openclaw/*)
            add_test_target "tests/unit/openclaw"
            add_test_target "tests/contract/openclaw"
            ;;
        roboclaws/maps/*)
            add_test_target "tests/contract/maps"
            ;;
        roboclaws/mcp/*)
            add_test_target "tests/contract/mcp"
            ;;
        roboclaws/household/*|roboclaws/molmo_cleanup/*)
            add_test_target "tests/unit/molmo_cleanup"
            add_test_target "tests/contract/molmo_cleanup"
            ;;
        roboclaws/agents/*)
            add_test_target "tests/contract/skills"
            add_test_target "tests/contract/dev_tools"
            ;;
        roboclaws/launch/*|roboclaws/devtools/*)
            add_test_target "tests/contract/dev_tools"
            ;;
        roboclaws/cli/*)
            add_test_target "tests/contract/mcp"
            add_test_target "tests/contract/molmo_cleanup"
            ;;
        examples/*)
            add_test_target "tests/unit/examples"
            ;;
        scripts/*.py|scripts/*/*.py)
            add_test_target "tests/unit/scripts"
            add_test_target "tests/contract/dev_tools"
            ;;
    esac
}

if [[ "${FORCE_TESTS:-0}" == "1" ]]; then
    echo "pre-commit: FORCE_TESTS=1 set — running full fast pytest"
    run_full_fast_tests
    exit 0
fi

STAGED_CONFIG="$(git diff --cached --name-only --diff-filter=ACMR -- '*.toml' '*.lock' || true)"
if [[ -n "$STAGED_CONFIG" ]]; then
    echo "pre-commit: staged dependency/config file — running full fast pytest"
    run_full_fast_tests
    exit 0
fi

declare -a TEST_TARGETS=()
while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    infer_tests_for_path "$path"
done <<< "$STAGED_PY"

if [[ "${#TEST_TARGETS[@]}" -eq 0 ]]; then
    echo "pre-commit: no scoped pytest target inferred — running full fast pytest"
    run_full_fast_tests
    exit 0
fi

echo "pre-commit: pytest scoped targets: ${TEST_TARGETS[*]}"
./scripts/dev/run_pytest_standalone.sh -m "not integration" -q --durations=5 "${TEST_TARGETS[@]}"
