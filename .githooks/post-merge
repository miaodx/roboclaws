#!/usr/bin/env bash
# Post-merge hook: run the integration tests in the background.
#
# Fires after `git merge` / `git pull`. Covers the tests excluded by the
# pre-commit hook — anything that needs Docker (pinned Gateway image)
# or real model-provider API calls. Runs non-blocking so `git pull`
# returns immediately; check progress + result in:
#
#     tail -f .git/integration-last.log
#
# Exits 0 always — a failing integration test should not un-merge the
# incoming changes. Report the failure on the next commit or in CI.
#
# Bypass: set SKIP_INTEGRATION=1 in the env before running `git pull`.

set -euo pipefail

if [[ "${SKIP_INTEGRATION:-0}" == "1" ]]; then
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [[ ! -x scripts/dev/run_pytest_standalone.sh ]]; then
    echo "post-merge: scripts/dev/run_pytest_standalone.sh missing or not executable — skipping integration run" >&2
    exit 0
fi

LOGFILE=.git/integration-last.log
{
    echo "=== integration run started $(date -Is) ==="
    echo "=== HEAD: $(git rev-parse --short HEAD) ($(git log -1 --format=%s)) ==="
    ./scripts/dev/run_pytest_standalone.sh -m integration -q --durations=10
    echo "=== integration run finished $(date -Is) rc=$? ==="
} >"$LOGFILE" 2>&1 &

disown $! 2>/dev/null || true

echo "post-merge: integration tests running in background (pid $!, log: $LOGFILE)"
echo "           → tail -f $LOGFILE   to watch"
echo "           → or skip next time with  SKIP_INTEGRATION=1 git pull"
exit 0
